{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LLM Actions",
  "version": "0.1.0",
  "identifier": "com.andrewmmc.llm-actions",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LLM Actions — Settings",
        "width": 900,
        "height": 650,
        "resizable": true,
        "visible": false,
        "label": "settings"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  }
}
