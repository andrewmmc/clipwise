# =============================================================================
# macOS Code Signing & Notarization (Developer ID — outside App Store)
# =============================================================================

# --- Signing ---
# Your signing identity from: security find-identity -v -p codesigning
# Example: "Developer ID Application: Your Name (TEAMID)"
APPLE_SIGNING_IDENTITY=

# --- Notarization (required for Developer ID distribution) ---
# App Store Connect API Key
# Create at: https://appstoreconnect.apple.com/access/integrations/api/subs
APPLE_API_ISSUER=
APPLE_API_KEY=
APPLE_API_KEY_PATH=

# --- CI-only (not needed for local builds if cert is in your keychain) ---
# Base64-encoded .p12 certificate:
#   openssl base64 -A -in certificate.p12 -out certificate-base64.txt
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=
