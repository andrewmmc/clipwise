{
  "name": "clipwise",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "sh -c 'if [ \"$(uname)\" = \"Darwin\" ]; then tauri dev --config src-tauri/tauri.macos.conf.json; else tauri dev; fi'",
    "tauri:dev:appstore": "tauri dev --config src-tauri/tauri.appstore.conf.json -- --no-default-features",
    "tauri:build": "sh -c 'if [ \"$(uname)\" = \"Darwin\" ]; then tauri build --config src-tauri/tauri.macos.conf.json; else tauri build; fi'",
    "tauri:build:appstore": "tauri build --config src-tauri/tauri.appstore.conf.json -- --no-default-features --features custom-protocol",
    "tauri:build-debug": "sh -c 'if [ \"$(uname)\" = \"Darwin\" ]; then tauri build --debug --config src-tauri/tauri.macos.conf.json; else tauri build --debug; fi'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "lefthook install",
    "gen-types": "cd src-tauri && TS_RS_EXPORT_DIR=../src/types/bindings cargo test --features ts export_bindings"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.0.4",
    "vitest": "^4.1.4"
  }
}
